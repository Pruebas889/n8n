      "parameters": {
        "jsCode": "// 1. Recuperamos la URL de la imagen que generaste en el paso anterior\nconst urlImagen = $('Code in JavaScript1').first().json.urlImagen;\n\n// 2. Creamos una lista vacía para guardar solo los datos válidos\nconst listaEnvio = [];\n\n// 3. Recorremos todas las filas que llegaron de Google Sheets\nfor (const item of items) {\n  \n  // Obtenemos el valor de la columna \"Cédula\"\n  // ¡IMPORTANTE!: Asegúrate que en tu Excel la columna se llame \"Cédula\" (con tilde y mayúscula inicial)\n  // Si en tu Excel dice \"cedula\", cambia lo de abajo por item.json[\"cedula\"]\n  const numeroCedula = item.json[\"Cédula\"];\n\n  // 4. CONDICIÓN: Si existe la cédula y no está vacía\n  if (numeroCedula && numeroCedula.toString().trim() !== \"\") {\n    \n    // Agregamos a la lista final solo lo que nos interesa\n    listaEnvio.push({\n      json: {\n        cedula: numeroCedula, // Aquí va solo la cédula limpia\n        urlImagen: urlImagen  // Y la URL de la imagen para el envío\n      }\n    });\n  }\n}\n\n// 5. Devolvemos la lista limpia. El siguiente nodo se ejecutará una vez por cada elemento de esta lista.\nreturn listaEnvio;"
      },
