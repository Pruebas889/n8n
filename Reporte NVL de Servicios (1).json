    {
      "parameters": {
        "jsCode": "// 1. Definimos el umbral en Bytes (218 KB * 1024)\nconst UMBRAL_BYTES = 244 * 1024; \n\nlet rawValue = 0;\n\n// Buscamos dentro de los objetos binarios\nfor (const k in items[0].binary) {\n  const binary = items[0].binary[k];\n  if (binary && binary.fileSize) {\n    // IMPORTANTE: Limpiamos el valor por si viene con texto tipo \"218 kB\"\n    // parseFloat extraerá solo el número '218' ignorando las letras\n    let size = parseFloat(binary.fileSize);\n    \n    // Si el texto original contenía \"kB\", lo multiplicamos por 1024 para tener bytes reales\n    // Si ya era un número grande (bytes), lo dejamos tal cual\n    if (binary.fileSize.toString().toLowerCase().includes('kb')) {\n       rawValue = size * 1024;\n    } else {\n       rawValue = size;\n    }\n    break; \n  }\n}\n\n// 2. Ahora la comparación será numérica y correcta\nconst esError = rawValue >= UMBRAL_BYTES;\n\nreturn [{\n  json: {\n    tamañoBytes: rawValue,\n    tamañoKB: parseFloat((rawValue / 1024).toFixed(2)),\n    esError: esError\n  },\n  binary: items[0].binary\n}];"
      },
