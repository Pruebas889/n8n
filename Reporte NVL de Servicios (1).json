    {
      "parameters": {
        "jsCode": "// 1. Recuperamos la URL de la imagen del nodo Code in JavaScript1\nconst urlImagen = $('Code in JavaScript1').first().json.urlImagen;\n\n// 2. Creamos una lista para guardar solo los correos válidos\nconst emailList = [];\n\n// 3. Recorremos todas las filas que llegaron del Google Sheets (Get Email Recipients)\nfor (const item of items) {\n  \n  // Obtenemos el valor de la columna \"Correo\"\n  const correo = item.json[\"correos\"];\n\n  // 4. CONDICIÓN: Si existe el correo y no está vacío\n  if (correo && correo.toString().trim() !== \"\") {\n    \n    emailList.push(correo.toString().trim());\n  }\n}\n\n// 5. CONDICIÓN DE SALIDA: Si la lista de correos está vacía, no devolvemos nada y el flujo termina aquí.\nif (emailList.length === 0) {\n    return []; // No devuelve ítems, el flujo se detiene.\n}\n\n// 6. Unimos todos los correos en una sola cadena separada por comas (formato aceptado por Gmail)\nconst recipients = emailList.join(',');\n\n// 7. Devolvemos un solo objeto con las dos variables que necesitamos en el nodo Gmail\nreturn [{\n    json: {\n        email: recipients,   // La lista de correos para el campo 'sendTo'\n        urlImagen: urlImagen // Y la URL de la imagen para el cuerpo del email\n    }\n}];"
      },
